{
  "name": "streamium",
  "version": "0.1.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "start": "node server.js",
    "desktop:db": "node scripts/create-desktop-db.mjs",
    "desktop:prisma": "prisma generate --schema prisma/schema.local.prisma",
    "predesktop:dev": "pnpm desktop:prisma",
    "predesktop:build": "pnpm desktop:db && pnpm desktop:prisma",
    "desktop:dev": "cross-env APP_DESKTOP=true APP_USER_DATA_PATH=.desktop APP_CONFIG_PATH=.desktop/config.json APP_DB_PATH=.desktop/streamium.db ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:build": "pnpm build && electron-builder"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.9.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.0.0",
    "vite": "^5.4.11",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@melt-ui/pp": "^0.3.2",
    "@prisma/client": "5.22.0",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@tiptap/core": "^2.9.1",
    "@tiptap/extension-link": "^2.9.1",
    "@tiptap/starter-kit": "^2.9.1",
    "@tiptap/suggestion": "^2.9.1",
    "@types/sharp": "^0.31.1",
    "emoji-mart": "^5.6.0",
    "mysql2": "^3.11.4",
    "prisma": "5.22.0",
    "sharp": "^0.33.5",
    "svelte": "^5.0.0",
    "svelte-preprocess": "^6.0.3",
    "svelte-sequential-preprocessor": "^2.0.2",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2"
    },
    "ignoredBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "svelte-preprocess"
    ],
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.streamium.app",
    "productName": "Streamium",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "build/**",
      "desktop/**",
      "prisma/generated/**",
      "server.js",
      "package.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "desktop/assets/streamium.db",
        "to": "streamium.db"
      }
    ],
    "asarUnpack": [
      "node_modules/.prisma/**",
      "node_modules/@prisma/client/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
